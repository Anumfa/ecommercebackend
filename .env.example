# MongoDB database connection string (MongoDB Atlas)
DATABASE=your_mongodb_connection_uri

# Server configuration
PORT=9000
NODE_ENV=development

# Cloudinary configuration (for file/image uploads)
Cloudname=your_cloudinary_cloud_name
Cloudkey=your_cloudinary_api_key
Cloudsecret=your_cloudinary_api_secret

# Email setup (Nodemailer)
Gmailuser=your_gmail_username@gmail.com
Gmailpassword=your_gmail_app_password

# JWT configuration
jwtsecret=your_super_secret_jwt_key
jwtexpiry=1d
